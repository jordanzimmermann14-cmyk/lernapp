# Supabase-Zugangsdaten für die geräteübergreifende Synchronisierung.
# Kopiere diese Datei zu .env.local und trage die Werte aus deinem Supabase-Projekt ein
# (Supabase Dashboard -> Project Settings -> API).
# Diese Werte sind öffentlich unbedenklich (Schutz über Row Level Security).

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
