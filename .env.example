# Supabase-Zugangsdaten für die geräteübergreifende Synchronisierung.
# Kopiere diese Datei zu .env.local und trage die Werte aus deinem Supabase-Projekt ein
# (Supabase Dashboard -> Project Settings -> API).
# Diese Werte sind öffentlich unbedenklich (Schutz über Row Level Security).

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Feste Produktions-URL für den Magic-Link-Rücksprung nach dem Login.
# WICHTIG in Vercel setzen (z.B. https://lernapp-chi-five.vercel.app) — sonst führt
# ein Login von einer alten Deployment-URL aus dorthin zurück statt zur echten Domain.
# Lokal leer lassen (fällt automatisch auf http://localhost:5173 zurück).
VITE_SITE_URL=
